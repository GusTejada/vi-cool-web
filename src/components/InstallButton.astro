---
import { getLangFromUrl, useTranslations } from '../assets/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const installText = lang === 'es' ? 'Instalar App' : 'Install App';
const iosText = lang === 'es' 
  ? 'Para instalar: pulsa el botón de compartir y elige "Añadir a la pantalla de inicio"' 
  : 'To install: tap the share button and choose "Add to Home Screen"';
---

<div id="pwa-install-container" class="install-container">
  <button id="pwa-install-btn" class="btn btn-pwa">
    <span class="icon">📱</span> <span id="btn-text">{installText}</span>
  </button>
  <div id="ios-instructions" class="ios-info" style="display: none;">
    <p>{iosText} <span>➔</span></p>
  </div>
</div>

<style>
  .install-container {
    padding: 2rem 0;
    text-align: center;
    position: relative;
    z-index: 1000;
  }
  .btn-pwa {
    background-color: var(--primary-green);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 auto;
    box-shadow: 0 4px 15px rgba(60, 109, 93, 0.3);
    padding: 0.8rem 1.5rem;
    border: none;
    border-radius: 50px;
    color: white;
    font-weight: bold;
    cursor: pointer;
    transition: 0.3s;
  }
  .btn-pwa:hover {
    transform: translateY(-2px);
    background-color: var(--primary-gold);
  }
  .ios-info {
    background: white;
    padding: 1rem;
    border-radius: 8px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    margin: 1rem auto;
    max-width: 320px;
    border: 2px solid var(--primary-gold);
    animation: bounce 2s infinite;
  }
  .ios-info p {
    font-size: 0.9rem;
    margin: 0;
    font-weight: 600;
    color: var(--text-dark);
  }
  .ios-info span {
    color: var(--primary-gold);
    font-size: 1.2rem;
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% {transform: translateY(0);}
    40% {transform: translateY(-10px);}
    60% {transform: translateY(-5px);}
  }
</style>

<script>
  let deferredPrompt;
  const installContainer = document.getElementById('pwa-install-container');
  const installBtn = document.getElementById('pwa-install-btn');
  const iosInfo = document.getElementById('ios-instructions');

  // Helper to check if already installed
  const isStandalone = () => {
    return (window.navigator as any).standalone || window.matchMedia('(display-mode: standalone)').matches;
  };

  // Helper to check if iOS
  const isIos = () => {
    return /iPad|iPhone|iPod/.test(navigator.userAgent) && !(window as any).MSStream;
  };

  window.addEventListener('beforeinstallprompt', (e) => {
    console.log('PWA: beforeinstallprompt event fired');
    e.preventDefault();
    deferredPrompt = e;
    if (installContainer && !isStandalone()) {
      installContainer.style.display = 'block';
      if (installBtn) installBtn.style.display = 'inline-flex';
    }
  });

  // Handle iOS manually
  window.addEventListener('DOMContentLoaded', () => {
    if (isIos() && !isStandalone()) {
      if (installContainer) {
        installContainer.style.display = 'block';
        if (installBtn) installBtn.style.display = 'none';
        if (iosInfo) iosInfo.style.display = 'block';
      }
    }
  });

  installBtn?.addEventListener('click', async () => {
    if (!deferredPrompt) {
      console.log('PWA: No deferredPrompt available');
      return;
    }
    deferredPrompt.prompt();
    const { outcome } = await deferredPrompt.userChoice;
    console.log(`PWA: User response to the install prompt: ${outcome}`);
    deferredPrompt = null;
    if (installContainer) {
      installContainer.style.display = 'none';
    }
  });

  window.addEventListener('appinstalled', (evt) => {
    console.log('PWA: appinstalled event fired');
    if (installContainer) {
      installContainer.style.display = 'none';
    }
  });
</script>
