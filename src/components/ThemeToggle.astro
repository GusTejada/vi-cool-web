---
// src/components/ThemeToggle.astro
---
<button id="themeToggle" aria-label="Cambiar tema">
  <!-- Puedes poner iconos aquí (ej. Sol y Luna) -->
  <span class="light-icon">☀️</span>
  <span class="dark-icon">🌙</span>
</button>

<script>
  const handleToggleClick = () => {
    const element = document.documentElement;
    element.classList.toggle("dark");

    const isDark = element.classList.contains("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  };

  // Añadir el evento al botón
  document.getElementById("themeToggle")?.addEventListener("click", handleToggleClick);
</script>

<style>
  /* Estilos básicos para ocultar/mostrar el texto del botón según el tema */
  :global(.dark) .light-icon { display: inline; }
  :global(.dark) .dark-icon { display: none; }
  
  html:not(.dark) .light-icon { display: none; }
  html:not(.dark) .dark-icon { display: inline; }
</style>