---
import '../styles/global.css';

interface Props {
	title: string;
	lang: 'es' | 'en';
  description?: string;
  image?: string;
}

const { 
  title, 
  lang, 
  description = lang === 'es' ? 'Vi Cool Madrid - Restaurante gastronómico de Sergi Arola. Tapas creativas, cocas y raciones gourmet en el barrio de las Letras.' : 'Vi Cool Madrid - Gastronomic restaurant by Sergi Arola. Creative tapas, cocas, and gourmet portions in the Letras district.',
  image = '/img/ViCool.jpeg'
} = Astro.props;

const siteUrl = 'https://vicoolmadrid.com';
const canonicalURL = new URL(Astro.url.pathname, siteUrl);

// Hreflang logic
const esURL = new URL(Astro.url.pathname.replace(/^\/en/, ''), siteUrl);
const enURL = new URL('/en' + Astro.url.pathname.replace(/^\/en/, ''), siteUrl);

// JSON-LD Structured Data
const restaurantSchema = {
  "@context": "https://schema.org",
  "@type": "Restaurant",
  "name": "Vi Cool Madrid",
  "image": siteUrl + image,
  "url": siteUrl,
  "author": {
    "@type": "Person",
    "name": "Sergi Arola"
  },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Calle de Huertas, 12",
    "addressLocality": "Madrid",
    "postalCode": "28012",
    "addressCountry": "ES"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.4140,
    "longitude": -3.6991
  },
  "telephone": "+34910000000",
  "servesCuisine": "Modern Spanish",
  "priceRange": "$$$",
  "openingHours": "Mo-Su 13:30-16:00, 20:30-23:30"
};
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
    <!-- Primary Meta Tags -->
		<title>{title} | Vi Cool Madrid</title>
		<meta name="title" content={`${title} | Vi Cool Madrid`} />
		<meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Hreflang Tags -->
    <link rel="alternate" hreflang="es" href={esURL} />
    <link rel="alternate" hreflang="en" href={enURL} />
    <link rel="alternate" hreflang="x-default" href={esURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={`${title} | Vi Cool Madrid`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, siteUrl)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={`${title} | Vi Cool Madrid`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, siteUrl)} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(restaurantSchema)} />

    <!-- PWA -->
    <meta name="theme-color" content="#3c6d5d" />
    <link rel="apple-touch-icon" href="/img/pwa-192x192.png" />
	</head>
	<body>
		<slot />
	</body>
</html>
