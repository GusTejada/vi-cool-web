---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { useTranslations } from '../assets/utils';

const t = useTranslations('es');

const images = [
	'/img/ViCool_1.jpeg', '/img/ViCool_2.jpeg', '/img/ViCool_3.jpeg',
	'/img/ViCool_4.jpeg', '/img/ViCool_5.jpeg', '/img/ViCool_6.jpeg',
	'/img/ViCool_7.jpeg', '/img/ViCool_8.jpeg', '/img/ViCool_9.jpeg'
];
---

<BaseLayout title={t('nav.galeria')} lang="es">
	<Navigation />
	
	<main class="container page-content">
		<h1>Galería</h1>
		<p class="subtitle">Un vistazo a nuestra cocina y ambiente.</p>
		
		<div class="gallery-grid">
			{images.map(img => (
				<div class="gallery-item">
					<img src={img} alt="Vi Cool" loading="lazy" />
				</div>
			))}
		</div>
	</main>

	<Footer />
</BaseLayout>

<style>
	.page-content { padding: 4rem 1.5rem; }
	.subtitle { margin-bottom: 3rem; text-align: center; }
	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 1.5rem;
	}
	.gallery-item img {
		width: 100%;
		height: 300px;
		object-fit: cover;
		border-radius: 8px;
		transition: 0.3s;
	}
	.gallery-item:hover img {
		transform: scale(1.02);
		box-shadow: 0 10px 20px rgba(0,0,0,0.1);
	}
</style>
