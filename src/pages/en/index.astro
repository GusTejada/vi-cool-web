---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import InstagramFeed from '../../components/InstagramFeed.astro';
import GoogleReviews from '../../components/GoogleReviews.astro';
import InstallButton from '../../components/InstallButton.astro';
import { useTranslations } from '../../assets/utils';

const t = useTranslations('en');


	interface GoogleReview {
  author_name: string;
  profile_photo_url: string;
  rating: number;
  relative_time_description: string;
  text: string;
  time: number;
}
	// src/components/Reviews.astro
const PLACE_ID = 'ChIJT_76DiuuEmsRWsoyG8BnY24'; 
const API_KEY = import.meta.env.GOOGLE_MAPS_API_KEY;

// Es recomendable usar la nueva URL de la API de Places (New) o asegurar que los campos son correctos
const url = `https://maps.googleapis.com/maps/api/place/details/json?place_id=${PLACE_ID}&fields=reviews,rating&key=${API_KEY}&language=es`;

const response = await fetch(url);
const data = await response.json();

// Si Google devuelve un error, lo veremos en la consola del terminal al hacer npm run dev
if (data.status !== 'OK') {
  console.error("Error de Google APAAI:", data.error_message || data.status);
}

const reviews: GoogleReview[] = data.result?.reviews || [];
---

<BaseLayout title={t('nav.home')} lang="en">
	<Navigation />
	
	<main>
		<section class="hero" style="background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('/img/ViCool.jpeg');">
			<div class="container hero-content">
				<h1>{t('home.welcome')}</h1>
				<p>{t('home.subtitle')}</p>
				<div class="hero-actions">
					<a href="/en/reservas" class="btn">{t('nav.reservas')}</a>
					<a href="/en/carta" class="btn btn-green">{t('nav.carta')}</a>
				</div>
			</div>
		</section>

		<InstallButton />

		<section class="intro">
			<div class="container grid-2">
				<div class="text">
					<h2>Tradition & Modernity</h2>
					<p>At Vi Cool, Sergi Arola reinterprets classics of Spanish cuisine with a vanguard and casual touch. A space designed to share and enjoy authentic flavors in a unique atmosphere.</p>
				</div>
				<div class="image">
					<img src="/img/ViCool_1.jpeg" alt="Vi Cool Restaurant" class="rounded" />
				</div>
			</div>
		</section>

		<InstagramFeed />
		<GoogleReviews />
hola
		<section class="reviews-grid">
  {reviews.map((review) => (
    <div class="review-card">
      <img src={review.profile_photo_url} alt={review.author_name} />
      <strong>{review.author_name}</strong>
      <p>{"⭐".repeat(review.rating)}</p>
      <p>{review.text}</p>
    </div>
  ))}
  adios
</section>
	</main>

	<Footer />
</BaseLayout>


<style>
	.hero {
		height: 80vh;
		background-size: cover;
		background-position: center;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		color: white;
	}
	.hero h1 {
		font-size: 3.5rem;
		margin-bottom: 1rem;
		color: var(--primary-gold);
	}
	.hero p {
		font-size: 1.5rem;
		margin-bottom: 2rem;
		font-weight: 300;
	}
	.hero-actions {
		display: flex;
		gap: 1rem;
		justify-content: center;
	}
	.grid-2 {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
	}
	.rounded {
		border-radius: 12px;
		box-shadow: 0 10px 30px rgba(0,0,0,0.1);
	}
	@media (max-width: 768px) {
		.hero h1 { font-size: 2.5rem; }
		.hero p { font-size: 1.2rem; }
		.grid-2 { grid-template-columns: 1fr; gap: 2rem; }
		.hero-actions { flex-direction: column; }
	}
</style>

